{
  "name":
    "@themartiancompany/fs",
  "description":
    "Platform-independent File System ('fs') module.",
  "version":
    "0.0.15",
  "homepage":
    "https://github.com/themartiancompany/tmcfs",
  "license":
    "AGPL-3.0",
  "bugs": {
    "url":
      "https://github.com/themartiancompany/tmcfs/issues"
  },
  "author":
    { "name":
        "Pellegrino Prevete",
      "email":
        "pellegrinoprevete@gmail.com",
      "url":
        "https://github.com/tallero"
  },
  "keywords": [
    "fs",
    "tmcfs",
    "node:fs",
    "system",
    "file",
    "directory",
    "opfs",
    "origin",
    "private",
    "worker",
    "sync",
    "async",
    "upload",
    "download",
    "zip",
    "unzip"
  ],
  "type":
    "commonjs",
  "files": [
    "COPYING",
    "AUTHORS.md",
    "README.md",
    "dist",
    "eslint.config.mjs",
    "fs-worker.webpack.config.cjs",
    "fs",
    "package.json",
    "webpack.config.cjs"
  ],
  "source":
    "./fs",
  "man":
    "./man/tmcfs.1",
  "main":
    "fs",
  "sideEffects":
    false,
  "scripts": {
    "lint":
      "npx eslint .",
    "prebuild":
      "npm run lint",
    "build":
      "npm install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/themartiancompany/tmcfs.git"
  },
  "devDependencies": {
    "@eslint/js":
      "^10.0.1",
    "eslint":
      "^10.3.0",
    "globals":
      "^17.3.0",
    "opfs":
      "npm:@themartiancompany/opfs@^2.0.10",
    "safely-serve":
      "^0.0.9",
    "web-worker":
      "^1.5.0",
    "webpack":
      "^5.102.1",
    "webpack-cli":
      "^6.0.1"
  },
  "dependencies": {
  },
  "optionalDependencies": {
    "opfs":
      "npm:@themartiancompany/opfs@^2.0.10"
  },
  "overrides": {
    "fs":
      "node:fs"
  },
  "scripts":
    { "build":
        "npm run lint; npm run build-fs-worker; npm run build-lib",
    "build-fs-worker":
      "npx webpack --mode 'production' --config 'fs-worker.webpack.config.cjs' --stats-error-details && for _target in 'fs'; do cp 'fs-worker.js' 'dist/'${_target}; done",
      "build-lib":
        "npx webpack --mode 'production' --config 'webpack.config.cjs' --stats-error-details && mkdir 'dist' && mv 'fs.js' 'dist'",
      "lint":
        "npx eslint .",
      "start":
        "npx safely-serve 'dist/fs'",
      "test":
        "echo \"Error: no test specified\" && exit 1" }
}
